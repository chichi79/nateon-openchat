{
  "name": "nateon-openchat-web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./node_modules/@react-router/dev/bin.js build",
    "dev": "node ./node_modules/@react-router/dev/bin.js dev",
    "start": "powershell -NoProfile -Command \"$p=$env:SERVER_PORT; if(-not $p){$p=8080}; vite preview --host 0.0.0.0 --port $p\"",
    "typecheck": "node ./node_modules/@react-router/dev/bin.js typegen && node ./node_modules/typescript/bin/tsc",
    "lint": "eslint .",
    "deploy:hosting": "npm run build && npx firebase deploy --only hosting",
    "deploy": "npm run build && npx firebase deploy"
  },
  "dependencies": {
    "@react-router/node": "^7.15.0",
    "@react-router/serve": "^7.15.0",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "isbot": "^5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@react-router/dev": "^7.15.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^20",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "esbuild": "^0.25.12",
    "eslint": "^9.33.0",
    "firebase-tools": "^14.24.0",
    "globals": "^16.3.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.40.0",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
