SERVER_PORT=8083
VITE_OAUTH_LOGIN_URL=/social/login

# Firebase Web (콘솔 > 프로젝트 설정 > 내 앱 > firebaseConfig)
# 모두 채워지면 클라이언트에서 Firebase 앱이 초기화됩니다. 비우면 초기화 생략.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 클라이언트 전용 Mock API (/api/openchat/*) 활성화 여부.
# dev/preview/배포 모두에서 동작. 실제 백엔드 연결 시 false 로 변경.
VITE_ENABLE_MOCK_API=true

# true 이면 Firebase Firestore에 방·메시지·멤버를 저장합니다 (VITE_FIREBASE_* 전부 필요, 콘솔에서 Firestore 활성화).
# 이 경우 root.tsx 에서 Mock fetch 인터셉터는 자동으로 설치되지 않습니다.
# Vercel에서 Firestore만 쓸 때: VITE_USE_FIRESTORE=true, VITE_ENABLE_MOCK_API=false, VITE_FIREBASE_* 6개 + Redeploy (README §3-1).
VITE_USE_FIRESTORE=false
