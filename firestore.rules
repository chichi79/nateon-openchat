rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 프로덕션에서는 반드시 교체하세요. 이 앱의 오픈채팅 어댑터는 브라우저에서 Firestore에 직접 접근합니다.
    // 인증·역할 검증 없이 열려 있으면 누구나 데이터를 읽고 쓸 수 있습니다.
    // 개발/프로토타입용으로만 사용하고, 배포 전에 match /rooms/... 등 세분화된 규칙과 App Check·Auth를 적용하세요.
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2030, 1, 1);
    }
  }
}
